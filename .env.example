# SupaBrain: Neural Memory on PostgreSQL
# Copy this file to .env and fill in your credentials

# =============================================================
# Option 1: Self-hosted PostgreSQL (recommended for low latency)
# =============================================================
# Run pgvector/pgvector:pg16 on your own server (Docker, LXC, VM...)
# Requires: PostgreSQL 16+ with pgvector extension

NM_MODE=postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/neural_memory

# Example with DDNS:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@nmem.yourdomain.org:5432/neural_memory

# =============================================================
# Option 2: Supabase Cloud
# =============================================================
# Create a project at https://supabase.com and use the connection string

# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=eyJ...your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# Session pooler (recommended for Supabase):
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Direct connection (alternative):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
